```gitignore
############################
# Visual Studio
############################
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

############################
# Build Folders
############################
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
publish/
artifacts/

############################
# ASP.NET Core / .NET
############################
project.lock.json
project.fragment.lock.json
ScaffoldingReadMe.txt

############################
# NuGet
############################
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

############################
# Environment Files
############################
.env
.env.*
appsettings.Development.json
appsettings.Local.json

############################
# SQL Server
############################
*.mdf
*.ldf

############################
# Test Results
############################
TestResults/
*.trx
*.coverage
*.coveragexml

############################
# ReSharper
############################
_ReSharper*/
*.ReSharper
*.DotSettings.user

############################
# VS Code / Rider
############################
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

.idea/
*.code-workspace

############################
# Angular
############################
node_modules/
dist/
.angular/cache/
out-tsc/
coverage/

############################
# NPM / Yarn Logs
############################
npm-debug.log*
yarn-debug.log*
yarn-error.log*

############################
# Temporary Files
############################
*.log
*.tmp
*.temp
~$*

############################
# Docker
############################
docker-compose.override.yml

############################
# Azure
############################
.publishsettings

############################
# OS Files
############################
.DS_Store
Thumbs.db

############################
# Misc
############################
.history/
.sass-cache/
connect.lock
libpeerconnection.log
testem.log
typings/
```
